# ─────────────────────────────────────────────────────────────────────────────
# StoryWeave — Environment Variables
#
# HOW TO USE
#   1. Copy this file:  cp .env.local.example .env.local
#   2. Fill in the values below
#   3. Never commit .env.local to git (it is already in .gitignore)
#
# VARIABLE NAMING
#   NEXT_PUBLIC_*  →  Safe to expose to the browser (bundled into client JS).
#                    Only put values here that are meant to be public.
#   Everything else  →  Server-only. Next.js keeps these out of the browser.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
#
# PostgreSQL connection string consumed by Prisma.
#
# Option A — Neon (free, serverless Postgres, recommended for Vercel deploys):
#   1. Sign up at https://neon.tech and create a project
#   2. Copy the connection string from the Dashboard (enable ?sslmode=require)
#   Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Option B — Local PostgreSQL:
#   Example: postgresql://postgres:password@localhost:5432/storyweave
#
# After setting this value run:
#   npx prisma generate        ← generates the Prisma client
#   npx prisma migrate dev --name init  ← creates the table and migration file
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require


# ── Stripe ────────────────────────────────────────────────────────────────────
#
# Where to find these:
#   Dashboard → Developers → API keys  https://dashboard.stripe.com/apikeys
#
# TEST keys (safe to use in development — no real money moves):
#   Publishable key starts with:  pk_test_
#   Secret key starts with:       sk_test_
#
# LIVE keys (production only — guard these carefully):
#   Publishable key starts with:  pk_live_
#   Secret key starts with:       sk_live_
#
# Rule of thumb: NEVER put sk_* keys anywhere the browser can read them.

# Publishable key — safe for the browser, used by Stripe.js / Elements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Secret key — server-only, used to create PaymentIntents and verify charges
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret — server-only, used to verify webhook payloads
# How to get this for LOCAL development (Stripe CLI):
#   1. Install Stripe CLI:  https://stripe.com/docs/stripe-cli
#   2. Login:               stripe login
#   3. Forward events:      stripe listen --forward-to localhost:3000/api/webhooks/stripe
#   4. Copy the "webhook signing secret" printed by that command (starts with whsec_)
#
# How to get this for PRODUCTION (Stripe Dashboard):
#   Dashboard → Developers → Webhooks → Add endpoint
#   URL: https://yourdomain.com/api/webhooks/stripe
#   Events to listen for: payment_intent.succeeded, payment_intent.payment_failed
#   After saving, reveal the "Signing secret" (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME


# ── Cloud Storage (S3 / Cloudflare R2) ───────────────────────────────────────
#
# Used to store generated PDFs so they survive across serverless function
# invocations and can be served via short-lived pre-signed download URLs.
#
# Leave ALL of these unset during local development — the app will fall back
# to serving PDFs straight from the /tmp directory.
#
# ── Option A: AWS S3 ─────────────────────────────────────────────────────────
#   1. Create an S3 bucket and set it to PRIVATE (no public-read ACL)
#   2. Create an IAM user with s3:PutObject + s3:GetObject on that bucket
#   3. Fill in the values below (leave STORAGE_ENDPOINT blank for S3)
#
# ── Option B: Cloudflare R2 (recommended — no egress fees) ───────────────────
#   1. Create an R2 bucket in the Cloudflare dashboard
#   2. Go to R2 → Manage R2 API Tokens → Create API Token
#      Permissions: Object Read & Write on the bucket you created
#   3. Copy the "Access Key ID" and "Secret Access Key"
#   4. Set STORAGE_ENDPOINT to your account's R2 S3-compatible URL:
#      https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# STORAGE_REGION  — use "auto" for R2; use your AWS region (e.g. us-east-1) for S3
# STORAGE_ENDPOINT — required for R2, leave blank for standard AWS S3

# ── Transactional Email (Resend) ─────────────────────────────────────────────
#
# Resend is a developer-friendly email API with a free tier of 3 000 emails/month.
# https://resend.com
#
# Setup:
#   1. Sign up at https://resend.com and create an API key
#      Dashboard → API Keys → Create API Key
#      Permission: "Sending access"
#   2. Verify your sending domain (Dashboard → Domains → Add Domain)
#   3. Fill in the values below
#
# Local testing without a verified domain:
#   Leave EMAIL_FROM as "onboarding@resend.dev" — Resend lets you send from
#   this address during development (the email goes to your Resend account's
#   verified email only).
#
# NEXT_PUBLIC_APP_URL is used to build the download link inside the "book ready"
# email.  Set it to your production domain on Vercel.  Locally, leave it unset
# and it will default to http://localhost:3000.

# ── Deployment ────────────────────────────────────────────────────────────────
#
# These are only needed in production.  Leave them unset locally.
#
# NEXT_APP_URL      — Your Vercel deployment URL (used by the PDF microservice
#                     to build the callback address).
#                     Example: https://storyweave.vercel.app
#
# PDF_SERVICE_URL   — Base URL of the Fly.io PDF microservice.
#                     Example: https://storyweave-pdf-service.fly.dev
#                     Leave unset in local dev — Puppeteer runs in-process.
#
# PDF_SERVICE_SECRET — A random secret shared between Vercel and the PDF service.
#                      Generate with: openssl rand -hex 32
#                      Set the identical value on BOTH platforms.

NEXT_APP_URL=https://your-app.vercel.app
PDF_SERVICE_URL=https://storyweave-pdf-service.fly.dev
PDF_SERVICE_SECRET=REPLACE_ME_openssl_rand_hex_32


# ── Transactional Email (Resend) ─────────────────────────────────────────────
#
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=StoryWeave <books@yourdomain.com>
NEXT_PUBLIC_APP_URL=https://yourdomain.com


STORAGE_BUCKET=your-bucket-name
STORAGE_REGION=auto
STORAGE_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=REPLACE_ME
STORAGE_SECRET_ACCESS_KEY=REPLACE_ME
